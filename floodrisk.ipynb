    "        vals_arr.append([(row[c]-df[c].min())/(df[c].max()-df[c].min()+1e-9) for c in dcols])\n",
    "    vals_mean = np.mean(vals_arr, axis=0).tolist(); vals_mean += vals_mean[:1]\n",
    "    ax.plot(angles, vals_mean, color=color, lw=2.5, label=label)\n",
    "    ax.fill(angles, vals_mean, color=color, alpha=0.15)\n",
    "ax.legend(loc='upper right', bbox_to_anchor=(1.35, 1.1), fontsize=8.5, facecolor=BG, labelcolor=TXT)\n",
    " \n",
    "# ── 3c: Heatmap — all wards × key risk indicators ────────────────────────────\n",
    "ax = fig3.add_subplot(3, 2, (3, 4))\n",
    "stl(ax, 'Ward Risk Profile Heatmap — Normalised Indicators')\n",
    "hcols = ['Poverty_Pct','Weak_Housing_Pct','Veg_Cover_Pct','Surface_Runoff_Pct',\n",
    "         'Avg_Discharge','Floodplain_Width_km','Elevation_m','Slope_deg',\n",
    "         'Drainage_Density','Overflow_Freq_yr','Avg_Rainfall_mm','Settlement_Exposed_Pct']\n",
    "hlabels = ['Poverty','Weak Housing','Veg Cover','Runoff','Discharge','Floodplain W.',\n",
    "           'Elevation','Slope','Drain. Density','Overflow Freq','Avg Rainfall','Settlement Exp.']\n",
    "df_h = df.set_index('Ward')[hcols].copy()\n",
    "df_h.columns = hlabels\n",
    "df_h_norm = (df_h - df_h.min()) / (df_h.max() - df_h.min() + 1e-9)\n",
    "df_h_norm.index = [f'W{int(i)}' for i in df_h_norm.index]\n",
    "df_h_sorted = df_h_norm.loc[[f'W{int(w)}' for w in preds_df.sort_values('Score',ascending=False)['Ward']]]\n",
    "sns.heatmap(df_h_sorted, ax=ax, cmap='RdYlGn_r', annot=True, fmt='.2f',\n",
    "            annot_kws={'size':7.5}, linewidths=0.4, cbar_kws={'shrink':0.6, 'label':'Normalised Value'})\n",
    "ax.tick_params(labelsize=8.5, colors=TXT)\n",
    "ax.set_xlabel(''); ax.set_ylabel('')\n",
    " \n",
    "# ── 3d: Vulnerability breakdown stacked ──────────────────────────────────────\n",
    "ax = fig3.add_subplot(3, 2, 5)\n",
    "stl(ax, 'Vulnerability Components by Ward\\n(stacked %)')\n",
    "sorted_w = preds_df.sort_values('Score', ascending=False)\n",
    "sw_labels = [f'W{int(w)}' for w in sorted_w['Ward']]\n",
    "sub_df = df.set_index('Ward').loc[sorted_w['Ward']]\n",
    "vc = ['Poverty_Pct','Weak_Housing_Pct','Livelihood_Dep_Pct']\n",
    "vnames = ['Poverty','Weak Housing','Livelihood Dep.']\n",
    "bottom = np.zeros(len(sub_df))\n",
    "for col, lbl, clr in zip(vc, vnames, [RED, ORG, PUR]):\n",
    "    ax.bar(sw_labels, sub_df[col], bottom=bottom, label=lbl, color=clr, alpha=0.88)\n",
    "    bottom += sub_df[col].values\n",
    "ax.set_ylabel('Vulnerability %'); ax.tick_params(axis='x', rotation=45)\n",
    "ax.legend(fontsize=8, facecolor=BG, labelcolor=TXT)\n",
    "ax2b = ax.twinx()\n",
    "ax2b.plot(range(len(sorted_w)), sorted_w['Score'].values, color=CYAN, marker='D',\n",
    "          ms=7, lw=2.5, label='Flood Score', zorder=5)\n",
    "ax2b.set_ylabel('Flood Score', color=CYAN); ax2b.tick_params(colors=CYAN)\n",
    "ax2b.spines[['top','right']].set_color('#30363d')\n",
    "ax2b.legend(fontsize=8, facecolor=BG, labelcolor=TXT, loc='upper right')\n",
    " \n",
    "# ── 3e: Box/strip chart — feature distributions by risk class ─────────────────\n",
    "ax = fig3.add_subplot(3, 2, 6)\n",
    "stl(ax, 'Key Feature Distributions by Risk Class')\n",
    "df_box = df[['Floodplain_Width_km','Avg_Discharge','Elevation_m','Surface_Runoff_Pct','Risk_Label']].copy()\n",
    "df_melt = df_box.melt(id_vars='Risk_Label', var_name='Feature', value_name='Value')\n",
    "# Normalise each feature for comparability\n",
    "for feat in df_melt['Feature'].unique():\n",
    "    mn = df_melt.loc[df_melt['Feature']==feat,'Value'].min()\n",
    "    mx = df_melt.loc[df_melt['Feature']==feat,'Value'].max()\n",
    "    df_melt.loc[df_melt['Feature']==feat,'Value'] = (df_melt.loc[df_melt['Feature']==feat,'Value']-mn)/(mx-mn+1e-9)\n",
    "pal = {k: v for k, v in risk_palette.items() if k in df_melt['Risk_Label'].unique()}\n",
    "sns.stripplot(data=df_melt, x='Feature', y='Value', hue='Risk_Label', palette=pal,\n",
    "              ax=ax, dodge=True, size=9, alpha=0.85, edgecolor='white', linewidth=0.5)\n",
    "ax.set_ylabel('Normalised Value'); ax.set_xlabel('')\n",
    "ax.tick_params(axis='x', labelsize=8.5)\n",
    "ax.legend(title='Risk Class', fontsize=8, facecolor=BG, labelcolor=TXT,\n",
    "          title_fontsize=8, labelspacing=0.3)\n",
    " \n",
    "fig3.suptitle('Muzarabani District — Flood Risk Executive Dashboard\\n'\n",
    "              'Section 3 of 3 : Ranked Risk · Multi-Indicator Profiles · Ward Heatmap',\n",
    "              fontsize=15, fontweight='bold', color=TXT, y=0.993)\n",
    "plt.tight_layout(rect=[0,0,1,0.988])\n",
    "plt.savefig('3_risk_dashboard.png', dpi=150, bbox_inches='tight', facecolor=DARK)\n",
    "print(\"  Saved: 3_risk_dashboard.png\")\n",
    " \n",
    "preds_df.to_csv('flood_risk_predictions.csv', index=False)\n",
    "print(\"\\nAll done! Files:\")\n",
    "print(\"  1_data_exploration.png\")\n",
    "print(\"  2_model_results.png\")\n",
    "print(\"  3_risk_dashboard.png\")\n",
    "print(\"  flood_risk_predictions.csv\")\n",
    " "
   ]
