   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════════════════════════\n",
   # ══════════════════════════════════════════════════════════════════════════════
# THEME
# ══════════════════════════════════════════════════════════════════════════════
DARK="#d3d8e0"; BG="#e6e9ed"; BG2="#d8dde5"; TXT="#0E0F0F"
BLUE='#388bfd'; ORG='#f0883e'; RED='#ff7b72'; GRN='#56d364'
PUR='#bc8cff'; YLW='#d29922'; CYAN='#39c5cf'; PINK='#f778ba'
MCOLORS = [BLUE, ORG, PUR, GRN]
 
def stl(ax, title, fs=11):
    ax.set_facecolor(BG2)
    ax.set_title(title, color=TXT, fontweight='bold', fontsize=fs, pad=8)
    ax.spines[['top','right']].set_visible(False)
    ax.spines[['left','bottom']].set_color('#30363d')
    ax.tick_params(colors=TXT, labelsize=8.5)
 
plt.rcParams.update({
    'text.color':TXT,'axes.labelcolor':TXT,'xtick.color':TXT,
    'ytick.color':TXT,'axes.facecolor':BG2,'figure.facecolor':DARK,
    'font.family':'DejaVu Sans'
})
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# 1. DATA LOADING\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "xl = pd.read_excel('Flood_risk_Analysis.xlsx', sheet_name=None)\n",
    "def load(name, cols):\n",
    "    d = xl[name].copy(); d.columns = cols; return d\n",
    " \n",
    "vuln  = load('Vulnerability Indicators',\n",
    "             ['Ward','Poverty_Pct','Weak_Housing_Pct','Livelihood_Dep_Pct','Disaster_Prep_Pct','Overall_Vuln_Pct'])\n",
    "river = load('River overflow characteristics',\n",
    "             ['Ward','River','Avg_Discharge','Floodplain_Width_km','Overflow_Freq_yr','Flooded_Area_ha'])[\n",
    "             ['Ward','Avg_Discharge','Floodplain_Width_km','Overflow_Freq_yr','Flooded_Area_ha']]\n",
    "elev  = load('Elevation and slope         ',\n",
    "             ['Ward','Elevation_m','Slope_deg','Vl'])[['Ward','Elevation_m','Slope_deg']]\n",
    "drain = load('Drainage density,Vulnerability', ['Ward','Drainage_Density','Drain_Flood_Suscept'])\n",
    "surf  = load('Surface conditions',\n",
    "             ['Ward','Veg_Cover_Pct','Surface_Runoff_Pct','Surface_Flood_Suscept_Pct'])\n",
    "infra = load('Infrastructure, Settlement',\n",
    "             ['Ward','Settlement_Exposed_Pct','Infra_Exposed_Pct','Overall_Exposed_Pct'])\n",
    "rain  = load('Rain Characteristics', ['Ward','Avg_Rainfall_mm','Max_Rainfall_mm','Flood_Freq_yr'])\n",
    "pop   = load('Population exposure',\n",
    "             ['Ward','Total_Pop','Pop_Exposed_Abs','Pop_Exposure_Pct'])[['Ward','Pop_Exposure_Pct']]\n",
    " \n",
    "df = vuln.copy()\n",
    "for d in [river, elev, drain, surf, infra, rain, pop]:\n",
    "    df = df.merge(d, on='Ward', how='left')\n",
    " \n",
    "for c in ['Avg_Rainfall_mm','Max_Rainfall_mm','Flood_Freq_yr','Pop_Exposure_Pct']:\n",
    "    df[c].fillna(df[c].median(), inplace=True)\n",
    " \n",
    "df['Flood_Risk_Score'] = df['Drain_Flood_Suscept']\n",
    "df['Risk_Label']  = df['Flood_Risk_Score'].apply(\n",
    "    lambda x: 'Very High' if x>=85 else ('High' if x>=70 else ('Moderate' if x>=55 else 'Low')))\n",
    "df['Y'] = (df['Flood_Risk_Score'] >= 70).astype(int)\n",
    " \n",
    "feat_cols = ['Poverty_Pct','Weak_Housing_Pct','Livelihood_Dep_Pct','Disaster_Prep_Pct',\n",
    "             'Avg_Discharge','Floodplain_Width_km','Overflow_Freq_yr','Flooded_Area_ha',\n",
    "             'Elevation_m','Slope_deg','Drainage_Density',\n",
    "             'Veg_Cover_Pct','Surface_Runoff_Pct',\n",
    "             'Settlement_Exposed_Pct','Infra_Exposed_Pct','Overall_Exposed_Pct',\n",
    "             'Avg_Rainfall_mm','Max_Rainfall_mm','Flood_Freq_yr','Pop_Exposure_Pct']\n",
    " \n",
    "X_raw = df[feat_cols].values\n",
    "y = df['Y'].values\n",
    "imp = SimpleImputer(strategy='median')\n",
    "scaler = StandardScaler()\n",
    "X  = imp.fit_transform(X_raw)\n",
    "Xs = scaler.fit_transform(X)\n",
    " \n",
    "wl = [f'W{int(w)}' for w in df['Ward']]\n",
    "risk_palette = {'Very High':RED,'High':ORG,'Moderate':YLW,'Low':GRN}\n",
    "rc4 = [risk_palette[r] for r in df['Risk_Label']]\n",
    " \n",
    "print(\"Data loaded — wards:\", df['Ward'].tolist())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 121,
   "id": "26c3d883-1f04-409b-b064-c70d79163dc1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "  Random Forest: Acc=0.909 AUC=0.964\n",
      "  Gradient Boosting: Acc=0.909 AUC=0.964\n",
      "  Logistic Regression: Acc=0.909 AUC=0.929\n",
      "  SVM: Acc=0.818 AUC=0.786\n"
     ]
    }
   ],
   "source": [
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# 2. MODEL TRAINING\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "mdefs = {\n",
    "    'Random Forest':       RandomForestClassifier(n_estimators=500, max_depth=3, min_samples_leaf=2, random_state=42),\n",
    "    'Gradient Boosting':   GradientBoostingClassifier(n_estimators=50, max_depth=2, learning_rate=0.1, min_samples_leaf=2, random_state=42),\n",
    "    'Logistic Regression': LogisticRegression(C=0.2, max_iter=2000),\n",
    "    'SVM':                 SVC(C=0.5, kernel='rbf', probability=True, random_state=42),\n",
    "}\n",
    " \n",
    "loo = LeaveOneOut()\n",
    "results, oof = {}, {}\n",
    "for name, mdl in mdefs.items():\n",
    "    preds, probs = [], []\n",
    "    for tr, te in loo.split(Xs):\n",
    "        Xtr, Xte = Xs[tr], Xs[te]; ytr = y[tr]\n",
    "        if len(np.unique(ytr)) < 2: probs.append(0.5); preds.append(0); continue\n",
    "        mdl.fit(Xtr, ytr)\n",
    "        cls = list(mdl.classes_); pp = mdl.predict_proba(Xte)[0]\n",
    "        p1 = pp[cls.index(1)] if 1 in cls else 0.0\n",
    "        probs.append(p1); preds.append(int(p1>=0.5))\n",
    "    oof[name] = np.array(probs)\n",
    "    acc = (np.array(preds)==y).mean()\n",
    "    try: auc = roc_auc_score(y, probs)\n",
    "    except: auc = 0.5\n",
    "    results[name] = {'acc':acc,'auc':auc,'preds':np.array(preds)}\n",
    "    print(f\"  {name}: Acc={acc:.3f} AUC={auc:.3f}\")\n",
    " \n",
    "rf = RandomForestClassifier(n_estimators=500, max_depth=3, min_samples_leaf=2, random_state=42).fit(Xs, y)\n",
    "gb = GradientBoostingClassifier(n_estimators=100, max_depth=2, learning_rate=0.1, min_samples_leaf=2, random_state=42).fit(Xs, y)\n",
    "ens = (rf.predict_proba(Xs)[:,1] + gb.predict_proba(Xs)[:,1]) / 2\n",
    "feat_imp  = pd.Series(rf.feature_importances_, index=feat_cols).sort_values(ascending=False)\n",
    "perm      = permutation_importance(rf, Xs, y, n_repeats=50, random_state=42)\n",
    "perm_imp  = pd.Series(perm.importances_mean, index=feat_cols).sort_values(ascending=False)\n",
    " \n",
    "rmap = {0:'Low/Moderate', 1:'High/Very High'}\n",
    "preds_df = pd.DataFrame({\n",
    "    'Ward': df['Ward'].values, 'Score': df['Flood_Risk_Score'].values,\n",
    "    'True_Risk': [rmap[v] for v in y],\n",
    "    'RF_Prob':  np.round(oof['Random Forest'],3),\n",
    "    'GB_Prob':  np.round(oof['Gradient Boosting'],3),\n",
    "    'LR_Prob':  np.round(oof['Logistic Regression'],3),\n",
    "    'SVM_Prob': np.round(oof['SVM'],3),\n",
    "    'Ensemble': np.round(ens,3)})\n",
    "preds_df['Predicted_Risk'] = (preds_df['Ensemble']>=0.5).map(rmap)\n",
    " "
   ]
  },
